{
  "name": "@vanillaes/absurdum",
  "version": "2.0.7",
  "description": "Absurdum - The Ridiculous Application of Reduce",
  "keywords": [
    "esm",
    "esmodules",
    "functional-programming",
    "operators",
    "lodash"
  ],
  "contributors": [
    {
      "name": "Evan Plaice",
      "email": "evan.plaice@gmail.com",
      "url": "https://evanplaice.com"
    },
    {
      "name": "Jens Kristian Vyff",
      "email": "kristianvyff@gmail.com",
      "url": "https://www.vyff.com"
    }
  ],
  "repository": "https://github.com/vanillaes/absurdum",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts",
      "browser": "./index.min.js"
    },
    "./arrays": {
      "import": "./src/arrays/index.js",
      "types": "./src/arrays/index.d.ts",
      "browser": "./src/arrays/index.min.js"
    },
    "./objects": {
      "import": "./src/objects/index.js",
      "types": "./src/objects/index.d.ts",
      "browser": "./src/objects/index.min.js"
    },
    "./strings": {
      "import": "./src/strings/index.js",
      "types": "./src/strings/index.d.ts",
      "browser": "./src/strings/index.min.js"
    }
  },
  "scripts": {
    "test": "esmtk test",
    "lint": "esmtk lint",
    "type": "esmtk type",
    "build": "esmtk minify && esmtk typings && node .config/docs.config.js",
    "clean": "esmtk clean --minify --typings && esmtk clean --custom docs/**/*.md",
    "preview": "esmtk preview",
    "preversion": "npm test && npm run lint && npm run type",
    "postversion": "git push --follow-tags"
  },
  "devDependencies": {
    "@vanillaes/esmtk": "^2.5.0",
    "docdown": "github:evanplaice/docdown",
    "glob": "^7.2.0"
  }
}
