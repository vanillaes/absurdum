{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Current File",
      "type": "node",
      "request": "launch",
      "program": "${file}"
    },
    {
      "name": "Test",
      "type": "node",
      "request": "launch",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/node_modules/.bin/esmtk",
      "cwd": "${workspaceFolder}",
      "args": ["test"],
      "console": "integratedTerminal",
    },
  ]
}
